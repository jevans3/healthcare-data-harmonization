package pas

// Description: Da Vinci PAS v2.1 Claim validation and transformation
//
// Validates and transforms FHIR Claim resources for prior authorization
// against PAS IG profiles. Used by the fhir-server ClaimProvider.
//
// Input:
//   FHIR Bundle containing Claim (use: "preauthorization") + supporting resources
//
// Output:
//   Validated Bundle with PAS-conformant resources
//
// Profiles validated:
//   - PAS Claim: http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-claim
//   - PAS Coverage: http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-coverage
//   - PAS Patient: http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-patient
//   - PAS ServiceRequest: http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-servicerequest
//
// CMS-0057-F: Supports electronic prior authorization API requirements

def PAS_Validate_Claim(bundle) {
  // Validate that the Bundle contains required resources
  var claim: where(bundle.entry, matchesCode($.resource.resourceType, "Claim"))

  if claim then {
    // Validate Claim.use is "preauthorization"
    if claim[0].resource.use != "preauthorization" then {
      error: "Claim.use must be 'preauthorization' for PAS submissions"
    }

    // Validate required references
    if !claim[0].resource.patient then {
      error: "Claim.patient is required"
    }
    if !claim[0].resource.provider then {
      error: "Claim.provider is required"
    }
    if !claim[0].resource.insurance then {
      error: "Claim.insurance is required"
    }

    // Pass through validated bundle
    $this: bundle
  } else {
    error: "Bundle must contain a Claim resource"
  }
}
